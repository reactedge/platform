<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://widgets-cdn.co.uk:8459/usp/styles/usp.css">
</head>
<body>

<h2>usp x2 Test</h2>
<script type="module">
    import { mount } from './src/widget.ts';
    import {loadContract} from "./src/lib/contract-resolver.js";
    const config = await loadContract('uk.json')
    const element = document.querySelector('usp-widget');

    await requestAnimationFrame(() => {
        mount(element, config);
    })
</script>

<usp-widget></usp-widget>

</body>
</html>